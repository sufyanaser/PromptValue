    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "openai": "^6.42.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.19",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.12",
