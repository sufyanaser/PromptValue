    "start": "node dist/server.cjs",
    "desktop": "electron .",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@google/genai": "^2.4.0",
